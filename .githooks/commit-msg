#!/usr/bin/env bash
set -euo pipefail

message_file="${1:?commit message file is required}"
subject="$(sed -n '1p' "$message_file" | tr -d '\r')"

case "$subject" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9][a-z0-9._/-]*\))?(!)?: .+'

if [[ "$subject" =~ $pattern ]]; then
  exit 0
fi

cat >&2 <<'EOF'
invalid commit message subject

expected format:
  type(scope): description

allowed types:
  feat fix docs style refactor perf test build ci chore revert

examples:
  feat(cli): add machine-readable diagnostics
  fix(install): support custom install dir
  chore(release): bump version to v1.0.0-alpha.4
EOF

echo >&2
echo "actual subject: $subject" >&2
exit 1
